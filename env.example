# 本番（Render など）では必ず設定してください。
# MongoDB Atlas で無料クラスターを作成し、「Connect」→ Drivers で URI をコピーします。
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority

# 任意（デフォルト short_shift_app）
# MONGO_DB_NAME=short_shift_app

# 任意（メールやドキュメントに載せる自サイトURL）
# PUBLIC_APP_URL=https://your-app.onrender.com

# URL の使い分け（画面のみの区別 — API は同一のため「守り」としては別途管理者トークン等が必要）
# - アルバイト向け（勤務希望のみ表示）: https://your-app.onrender.com/
# - 管理者向け（全タブ）: https://your-app.onrender.com/admin
